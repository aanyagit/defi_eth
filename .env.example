# Copy to .env and fill in. NEVER commit .env.

# Deployer key -----------------------------------------------------------
# Default is Anvil's first well-known account (LOCAL ONLY — never fund it on
# a public network). Replace with your own key before any testnet deploy.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Local Anvil ------------------------------------------------------------
LOCAL_RPC_URL=http://127.0.0.1:8545

# Testnets ---------------------------------------------------------------
# e.g. https://eth-sepolia.g.alchemy.com/v2/<key> or an Infura/public RPC
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# Contract verification --------------------------------------------------
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
